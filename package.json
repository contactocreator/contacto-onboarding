{
  "name": "contacto-onboarding",
  "version": "1.0.0",
  "description": "컨택토 온보딩 — 포트폴리오 자동 분석",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "node --watch server.js",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.53.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
